{
  "global": {
    "ask_for_confirmation_before_quitting": true,
    "check_for_updates_on_startup": true,
    "show_in_menu_bar": true,
    "show_profile_name_in_menu_bar": false,
    "unsafe_ui": false
  },
  "profiles": [
    {
      "name": "Default",
      "selected": true,
      "simple_modifications": [],
      "fn_function_keys": [],
      "complex_modifications": {
        "parameters": {
          "basic.simultaneous_threshold_milliseconds": 50,
          "basic.to_delayed_action_delay_milliseconds": 500,
          "basic.to_if_alone_timeout_milliseconds": 1000,
          "basic.to_if_held_down_threshold_milliseconds": 500,
          "mouse_motion_to_scroll.speed": 100
        },
        "rules": [
          {
            "description": "Right Command → Hyper Key (Apple keyboards)",
            "manipulators": [
              {
                "type": "basic",
                "from": {
                  "key_code": "right_command",
                  "modifiers": {
                    "optional": ["any"]
                  }
                },
                "to": [
                  {
                    "key_code": "left_shift",
                    "modifiers": ["left_command", "left_control", "left_option"]
                  }
                ],
                "conditions": [
                  {
                    "type": "device_if",
                    "identifiers": [
                      {
                        "vendor_id": 1452,
                        "is_keyboard": true
                      },
                      {
                        "vendor_id": 1452,
                        "product_id": 591,
                        "is_keyboard": true
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "description": "Hyper + Letter → App Switching",
            "manipulators": [
              {
                "type": "basic",
                "from": {
                  "key_code": "s",
                  "modifiers": {
                    "mandatory": [
                      "left_command",
                      "left_control",
                      "left_option",
                      "left_shift"
                    ]
                  }
                },
                "to": [
                  {
                    "shell_command": "open -a 'Slack'"
                  }
                ]
              },
              {
                "type": "basic",
                "from": {
                  "key_code": "c",
                  "modifiers": {
                    "mandatory": [
                      "left_command",
                      "left_control",
                      "left_option",
                      "left_shift"
                    ]
                  }
                },
                "to": [
                  {
                    "shell_command": "open -a 'Visual Studio Code'"
                  }
                ]
              },
              {
                "type": "basic",
                "from": {
                  "key_code": "b",
                  "modifiers": {
                    "mandatory": [
                      "left_command",
                      "left_control",
                      "left_option",
                      "left_shift"
                    ]
                  }
                },
                "to": [
                  {
                    "shell_command": "open -a 'Zen'"
                  }
                ]
              },
              {
                "type": "basic",
                "from": {
                  "key_code": "t",
                  "modifiers": {
                    "mandatory": [
                      "left_command",
                      "left_control",
                      "left_option",
                      "left_shift"
                    ]
                  }
                },
                "to": [
                  {
                    "shell_command": "open -a 'Terminal'"
                  }
                ]
              },
              {
                "type": "basic",
                "from": {
                  "key_code": "f",
                  "modifiers": {
                    "mandatory": [
                      "left_command",
                      "left_control",
                      "left_option",
                      "left_shift"
                    ]
                  }
                },
                "to": [
                  {
                    "shell_command": "open -a 'Finder'"
                  }
                ]
              }
            ]
          }
        ]
      },
      "devices": [],
      "virtual_hid_keyboard": {
        "country_code": 0,
        "indicate_sticky_modifier_keys_state": true,
        "mouse_key_xy_scale": 100
      }
    }
